      <column caption='zd_接口出' datatype='real' name='[zd_接口进 (复制)]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if  ZN(SUM([ifOutOctets])) &gt;= LOOKUP(ZN(SUM([ifOutOctets])), -1) then (ZN(SUM([ifOutOctets])) - LOOKUP(ZN(SUM([ifOutOctets])), -1))&#13;&#10;&#13;&#10;else ZN(SUM([ifOutOctets])) + POWER(2,32) - LOOKUP(ZN(SUM([ifOutOctets])), -1)&#13;&#10;&#13;&#10;end'>
