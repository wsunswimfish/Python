      <column caption='zd_接口进' datatype='real' name='[Calculation_163255546434912262]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if  ZN(SUM([ifInOctets])) &gt;= LOOKUP(ZN(SUM([ifInOctets])), -1) then (ZN(SUM([ifInOctets])) - LOOKUP(ZN(SUM([ifInOctets])), -1))&#13;&#10;&#13;&#10;else ZN(SUM([ifInOctets])) + POWER(2,32) - LOOKUP(ZN(SUM([ifInOctets])), -1)&#13;&#10;&#13;&#10;end'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column datatype='integer' name='[Id]' role='dimension' type='ordinal' />
      <column datatype='integer' name='[Number of Records]' role='measure' type='quantitative' user:auto-column='numrec'>
